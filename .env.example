APP_NAME=
NODE_ENV=
PORT=
CLIENT_ORIGIN=
PUBLIC_SITE_ORIGIN=

# Browser API calls use same-origin /api through the local/prod proxy.
# Comma-separated proxy IPs/CIDRs or Express names: loopback,linklocal,uniquelocal.
# Leave empty only when the API is reached directly without a reverse proxy.
TRUST_PROXY_CIDRS=

DATABASE_URL=
# Required by Prisma CLI commands. Use a direct/session PostgreSQL URL.
DIRECT_URL=
# Optional outside production. Use a direct/session PostgreSQL URL for LISTEN/NOTIFY.
DEV_DATABASE_RESET_DATABASE_URL=

JWT_SECRET=
# Optional previous key retained only for the access-token rotation window.
JWT_PREVIOUS_SECRET=
JWT_ISSUER=loresafe-api
JWT_AUDIENCE=loresafe-web
SESSION_COOKIE_NAME=
SESSION_COOKIE_SECURE=
# Server-side refresh session lifetime and short-lived access-token lifetime.
SESSION_TTL_SECONDS=
SESSION_ACCESS_TTL_SECONDS=

# Used only by the explicit development/test demo seed command.
DEMO_SEED_DATABASE_URL=
DEMO_SEED_CONFIRM=
DEMO_USER_EMAIL=
DEMO_USER_DISPLAY_NAME=
DEMO_USER_PASSWORD=

UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_BASE_URL=
R2_PRESIGNED_URL_TTL_SECONDS=
R2_CONNECTION_TIMEOUT_MS=
R2_REQUEST_TIMEOUT_MS=

# Deliberate Node HTTP budgets; headers must exceed keep-alive.
SERVER_HEADERS_TIMEOUT_MS=
SERVER_REQUEST_TIMEOUT_MS=
SERVER_KEEP_ALIVE_TIMEOUT_MS=
OPERATIONS_BEARER_TOKEN=

SENTRY_DSN=
SENTRY_ENVIRONMENT=
SENTRY_TRACES_SAMPLE_RATE=
SENTRY_ENABLE_DEBUG_ROUTE=

# Public browser Sentry config. Backend SENTRY_DSN stays server-only.
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=
VITE_SENTRY_TRACES_SAMPLE_RATE=
VITE_SENTRY_ENABLE_DEBUG_ROUTE=
VITE_PUBLIC_SITE_ORIGIN=
