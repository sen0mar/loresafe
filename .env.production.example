# Vercel/browser-public config
# Browser API calls use same-origin /api through the Vercel rewrite.

VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=
VITE_SENTRY_TRACES_SAMPLE_RATE=
VITE_SENTRY_ENABLE_DEBUG_ROUTE=
VITE_PUBLIC_SITE_ORIGIN=https://www.loresafe.org

# Render
APP_NAME=
NODE_ENV=
PORT=
CLIENT_ORIGIN=
# Comma-separated production browser origins. Preferred over CLIENT_ORIGIN for new deploys.
CLIENT_ORIGINS=https://www.loresafe.org
PUBLIC_SITE_ORIGIN=https://www.loresafe.org
# Explicit Render ingress/private proxy ranges. Never replace this with a hop count.
# Verify req.ip through the deployed Vercel and direct API paths before release.
TRUST_PROXY_CIDRS=loopback,linklocal,uniquelocal

DATABASE_URL=
# Required by Prisma CLI and migration commands. Use Neon's non-pooler endpoint.
DIRECT_URL=
# One-time showcase seed only. Remove these values after the verified production run.
SHOWCASE_SEED_NEON_ENDPOINT_ID=
SHOWCASE_SEED_CONFIRM=
SHOWCASE_RECRUITER_EMAIL=
SHOWCASE_USER_PASSWORD=
JWT_SECRET=
# Optional previous key retained only for the access-token rotation window.
JWT_PREVIOUS_SECRET=
JWT_ISSUER=loresafe-api
JWT_AUDIENCE=loresafe-web
SESSION_COOKIE_NAME=
SESSION_COOKIE_SECURE=
# Server-side refresh session lifetime and short-lived access-token lifetime.
SESSION_TTL_SECONDS=
SESSION_ACCESS_TTL_SECONDS=

UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_BASE_URL=
R2_PRESIGNED_URL_TTL_SECONDS=
R2_CONNECTION_TIMEOUT_MS=3000
R2_REQUEST_TIMEOUT_MS=15000

SERVER_HEADERS_TIMEOUT_MS=15000
SERVER_REQUEST_TIMEOUT_MS=30000
SERVER_KEEP_ALIVE_TIMEOUT_MS=5000
OPERATIONS_BEARER_TOKEN=

SENTRY_DSN=
SENTRY_ENVIRONMENT=
SENTRY_TRACES_SAMPLE_RATE=
SENTRY_ENABLE_DEBUG_ROUTE=
