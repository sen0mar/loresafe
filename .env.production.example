# Vercel/browser-public config
# Browser API calls use same-origin /api through the Vercel rewrite.

VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=
VITE_SENTRY_TRACES_SAMPLE_RATE=
VITE_SENTRY_ENABLE_DEBUG_ROUTE=
VITE_PUBLIC_SITE_ORIGIN=https://loresafe.org

# Render
APP_NAME=
NODE_ENV=
PORT=
CLIENT_ORIGIN=
# Comma-separated production browser origins. Preferred over CLIENT_ORIGIN for new deploys.
CLIENT_ORIGINS=
PUBLIC_SITE_ORIGIN=https://loresafe.org
TRUST_PROXY_HOPS=1

DATABASE_URL=
# Optional: set to false to fail instead of doing a final Prisma deploy attempt
# with advisory locks disabled after repeated advisory-lock timeouts.
PRISMA_MIGRATE_DEPLOY_DISABLE_LOCK_FALLBACK=

JWT_SECRET=
SESSION_COOKIE_NAME=
SESSION_COOKIE_SECURE=
SESSION_TTL_SECONDS=

DEMO_USER_EMAIL=
DEMO_USER_DISPLAY_NAME=
DEMO_USER_PASSWORD=

UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_BASE_URL=
R2_PRESIGNED_URL_TTL_SECONDS=

SENTRY_DSN=
SENTRY_ENVIRONMENT=
SENTRY_TRACES_SAMPLE_RATE=
SENTRY_ENABLE_DEBUG_ROUTE=
