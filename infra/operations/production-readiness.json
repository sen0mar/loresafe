{
  "version": 1,
  "livenessPath": "/api/health",
  "deepReadinessPath": "/api/health/ready",
  "metricsPath": "/api/health/metrics",
  "requiredAlertRules": [
    "api-liveness-failing",
    "api-high-error-rate",
    "api-high-latency",
    "storage-cleanup-failures"
  ],
  "backup": {
    "postgresRetentionDays": 14,
    "postgresPitrRequired": true,
    "objectRecoveryDays": 14,
    "restoreDrillMaximumAgeDays": 100,
    "rpoMinutes": 15,
    "rtoMinutes": 240
  },
  "requiredSecurityHeaders": [
    "content-security-policy",
    "permissions-policy",
    "referrer-policy",
    "strict-transport-security",
    "x-content-type-options",
    "x-frame-options"
  ]
}
