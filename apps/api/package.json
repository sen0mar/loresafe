{
  "name": "@loresafe/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.17.1 <23"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "build": "pnpm prisma:generate && tsc -p tsconfig.build.json",
    "typecheck": "pnpm prisma:generate && tsc -p tsconfig.json --noEmit",
    "test": "pnpm prisma:generate && vitest run",
    "test:coverage": "pnpm prisma:generate && vitest run --coverage",
    "test:integration:database": "pnpm prisma:generate && RUN_DATABASE_INTEGRATION_TESTS=1 vitest run --config vitest.integration.config.ts",
    "prisma:generate": "node -e \"require('node:fs').rmSync('src/generated/prisma', { recursive: true, force: true })\" && prisma generate",
    "prisma:status": "prisma migrate status",
    "prisma:check": "pnpm prisma:status && pnpm prisma:generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "node scripts/migrate-deploy-with-retry.mjs",
    "prisma:seed": "prisma db seed",
    "db:reset:development": "tsx scripts/reset-development-database.ts",
    "perf:seed-check": "tsx scripts/perf-seed-check.ts",
    "api:contract:generate": "tsx scripts/openapi-contract.ts --write",
    "api:contract:check": "tsx scripts/openapi-contract.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1069.0",
    "@aws-sdk/s3-request-presigner": "^3.1069.0",
    "@node-rs/argon2": "^2.0.2",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@sentry/node": "^10.58.0",
    "@upstash/redis": "^1.38.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "jose": "^6.2.3",
    "pg": "^8.21.0",
    "rate-limit-redis": "^5.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.2",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "prisma": "^7.8.0",
    "supertest": "^7.2.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
