generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
}

enum ClubVisibility {
  PUBLIC
  PRIVATE
  INVITE_ONLY
}

enum ClubMembershipRole {
  OWNER
  MODERATOR
  MEMBER
}

enum ProgressMode {
  STRICT
  SOFT
  BRAVE
  FINISHED
}

enum PostType {
  DISCUSSION
  QUESTION
  THEORY
  PREDICTION
  POLL
  REACTION
  REVIEW
  IMAGE_MEME
  QUOTE_COMMENTARY
  JUST_REACHED
}

enum PostStatus {
  VISIBLE
  HIDDEN
}

enum CommentStatus {
  VISIBLE
  HIDDEN
}

model User {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email          String    @db.VarChar(320)
  displayName    String    @map("display_name") @db.VarChar(80)
  username       String?   @db.VarChar(30)
  bio            String?   @db.VarChar(160)
  passwordHash   String    @map("password_hash")
  sessionVersion Int       @default(1) @map("session_version")
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  clubMemberships   ClubMembership[]
  clubBans          ClubBan[]
  createdClubInvites ClubInvite[] @relation("ClubInviteCreator")
  clubProgresses     ClubProgress[]
  progressHistory    ProgressHistory[]
  posts              Post[]
  comments           Comment[]
  postReactions      PostReaction[]
  commentReactions   CommentReaction[]

  @@unique([email], map: "users_email_active_unique", where: raw("\"deleted_at\" IS NULL"))
  @@unique([username], map: "users_username_active_unique", where: raw("\"deleted_at\" IS NULL AND \"username\" IS NOT NULL"))
  @@index([deletedAt], map: "users_deleted_at_idx")
  @@map("users")
}

model Club {
  id          String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title       String         @db.VarChar(120)
  slug        String         @db.VarChar(80)
  description String?        @db.VarChar(280)
  category    String?        @db.VarChar(60)
  rules       String?        @db.VarChar(2000)
  visibility  ClubVisibility @default(PUBLIC)
  createdAt   DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime       @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  memberships ClubMembership[]
  invites     ClubInvite[]
  bans        ClubBan[]
  milestones  Milestone[]
  progress    ClubProgress[]
  history     ProgressHistory[]
  posts       Post[]

  @@unique([slug], map: "clubs_slug_unique")
  @@index([visibility], map: "clubs_visibility_idx")
  @@map("clubs")
}

model ClubMembership {
  id        String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clubId    String             @map("club_id") @db.Uuid
  userId    String             @map("user_id") @db.Uuid
  role      ClubMembershipRole @default(MEMBER)
  createdAt DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime           @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, clubId], map: "club_memberships_user_id_club_id_unique")
  @@index([userId], map: "club_memberships_user_id_idx")
  @@index([clubId], map: "club_memberships_club_id_idx")
  @@map("club_memberships")
}

model ClubBan {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clubId    String    @map("club_id") @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  reason    String?   @db.VarChar(500)
  expiresAt DateTime? @map("expires_at") @db.Timestamptz(6)
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, clubId], map: "club_bans_user_id_club_id_idx")
  @@index([clubId, userId, revokedAt, expiresAt], map: "club_bans_active_lookup_idx")
  @@map("club_bans")
}

model ClubInvite {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clubId      String    @map("club_id") @db.Uuid
  createdById String    @map("created_by_id") @db.Uuid
  tokenHash   String    @map("token_hash") @db.VarChar(64)
  expiresAt   DateTime  @map("expires_at") @db.Timestamptz(6)
  maxUses     Int       @map("max_uses")
  usedCount   Int       @default(0) @map("used_count")
  revokedAt   DateTime? @map("revoked_at") @db.Timestamptz(6)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  club      Club @relation(fields: [clubId], references: [id], onDelete: Cascade)
  createdBy User @relation("ClubInviteCreator", fields: [createdById], references: [id], onDelete: Cascade)

  @@unique([tokenHash], map: "club_invites_token_hash_unique")
  @@index([clubId, createdAt], map: "club_invites_club_id_created_at_idx")
  @@index([createdById], map: "club_invites_created_by_id_idx")
  @@index([expiresAt], map: "club_invites_expires_at_idx")
  @@map("club_invites")
}

model Milestone {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clubId      String    @map("club_id") @db.Uuid
  position    Int
  safeTitle   String    @map("safe_title") @db.VarChar(120)
  fullTitle   String?   @map("full_title") @db.VarChar(160)
  description String?   @db.VarChar(500)
  spoilerName Boolean   @default(false) @map("spoiler_name")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  club                    Club              @relation(fields: [clubId], references: [id], onDelete: Cascade)
  currentClubProgresses   ClubProgress[]
  progressHistoryFromRows ProgressHistory[] @relation("ProgressHistoryFromMilestone")
  progressHistoryToRows   ProgressHistory[] @relation("ProgressHistoryToMilestone")
  posts                   Post[]
  comments                Comment[]

  @@unique([clubId, position], map: "milestones_club_id_position_unique")
  @@index([clubId], map: "milestones_club_id_idx")
  @@map("milestones")
}

model ClubProgress {
  id                 String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clubId             String       @map("club_id") @db.Uuid
  userId             String       @map("user_id") @db.Uuid
  currentMilestoneId String?      @map("current_milestone_id") @db.Uuid
  mode               ProgressMode @default(STRICT)
  createdAt          DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime     @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  club             Club       @relation(fields: [clubId], references: [id], onDelete: Cascade)
  user             User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  currentMilestone Milestone? @relation(fields: [currentMilestoneId], references: [id], onDelete: SetNull)

  @@unique([userId, clubId], map: "club_progress_user_id_club_id_unique")
  @@index([userId], map: "club_progress_user_id_idx")
  @@index([clubId], map: "club_progress_club_id_idx")
  @@index([currentMilestoneId], map: "club_progress_current_milestone_id_idx")
  @@map("club_progress")
}

model ProgressHistory {
  id              String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clubId          String       @map("club_id") @db.Uuid
  userId          String       @map("user_id") @db.Uuid
  fromMilestoneId String?      @map("from_milestone_id") @db.Uuid
  toMilestoneId   String?      @map("to_milestone_id") @db.Uuid
  fromMode        ProgressMode @map("from_mode")
  toMode          ProgressMode @map("to_mode")
  createdAt       DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)

  club          Club       @relation(fields: [clubId], references: [id], onDelete: Cascade)
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  fromMilestone Milestone? @relation("ProgressHistoryFromMilestone", fields: [fromMilestoneId], references: [id], onDelete: SetNull)
  toMilestone   Milestone? @relation("ProgressHistoryToMilestone", fields: [toMilestoneId], references: [id], onDelete: SetNull)

  @@index([userId, clubId, createdAt], map: "progress_history_user_id_club_id_created_at_idx")
  @@index([clubId, createdAt], map: "progress_history_club_id_created_at_idx")
  @@index([fromMilestoneId], map: "progress_history_from_milestone_id_idx")
  @@index([toMilestoneId], map: "progress_history_to_milestone_id_idx")
  @@map("progress_history")
}

model Post {
  id                  String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clubId              String     @map("club_id") @db.Uuid
  authorId            String     @map("author_id") @db.Uuid
  type                PostType
  title               String     @db.VarChar(160)
  body                String     @db.VarChar(8000)
  requiredMilestoneId String     @map("required_milestone_id") @db.Uuid
  status              PostStatus @default(VISIBLE)
  deletedAt           DateTime?  @map("deleted_at") @db.Timestamptz(6)
  createdAt           DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime   @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  club              Club      @relation(fields: [clubId], references: [id], onDelete: Cascade)
  author            User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  requiredMilestone Milestone @relation(fields: [requiredMilestoneId], references: [id], onDelete: Restrict)
  comments          Comment[]
  reactions         PostReaction[]

  @@index([clubId, status, deletedAt, createdAt], map: "posts_club_id_status_deleted_at_created_at_idx")
  @@index([clubId, status, deletedAt, createdAt, id], map: "posts_club_status_deleted_created_id_idx")
  @@index([clubId, authorId, status, deletedAt, createdAt, id], map: "posts_club_author_status_deleted_created_id_idx")
  @@index([clubId, requiredMilestoneId], map: "posts_club_id_required_milestone_id_idx")
  @@index([authorId], map: "posts_author_id_idx")
  @@index([requiredMilestoneId], map: "posts_required_milestone_id_idx")
  @@map("posts")
}

model PostReaction {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  postId    String   @map("post_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  emoji     String   @db.VarChar(16)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, postId, emoji], map: "post_reactions_user_id_post_id_emoji_unique")
  @@index([postId], map: "post_reactions_post_id_idx")
  @@index([postId, emoji], map: "post_reactions_post_id_emoji_idx")
  @@index([userId], map: "post_reactions_user_id_idx")
  @@map("post_reactions")
}

model Comment {
  id                  String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  postId              String        @map("post_id") @db.Uuid
  authorId            String        @map("author_id") @db.Uuid
  parentId            String?       @map("parent_id") @db.Uuid
  body                String        @db.VarChar(8000)
  requiredMilestoneId String        @map("required_milestone_id") @db.Uuid
  status              CommentStatus @default(VISIBLE)
  deletedAt           DateTime?     @map("deleted_at") @db.Timestamptz(6)
  createdAt           DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  post              Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  author            User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent            Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies           Comment[] @relation("CommentReplies")
  requiredMilestone Milestone @relation(fields: [requiredMilestoneId], references: [id], onDelete: Restrict)
  reactions         CommentReaction[]

  @@index([postId, status, deletedAt, createdAt], map: "comments_post_id_status_deleted_at_created_at_idx")
  @@index([postId, requiredMilestoneId], map: "comments_post_id_required_milestone_id_idx")
  @@index([authorId], map: "comments_author_id_idx")
  @@index([parentId], map: "comments_parent_id_idx")
  @@index([requiredMilestoneId], map: "comments_required_milestone_id_idx")
  @@map("comments")
}

model CommentReaction {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  commentId String   @map("comment_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  emoji     String   @db.VarChar(16)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, commentId, emoji], map: "comment_reactions_user_id_comment_id_emoji_unique")
  @@index([commentId], map: "comment_reactions_comment_id_idx")
  @@index([commentId, emoji], map: "comment_reactions_comment_id_emoji_idx")
  @@index([userId], map: "comment_reactions_user_id_idx")
  @@map("comment_reactions")
}
