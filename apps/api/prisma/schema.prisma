generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
}

enum ClubVisibility {
  PUBLIC
  PRIVATE
  INVITE_ONLY
}

enum ClubMembershipRole {
  OWNER
  MODERATOR
  MEMBER
}

enum ClubCategory {
  BOOKS
  TV_SHOWS
  ANIME
  MANGA
  MOVIES
  GAMES
  PODCASTS
  COURSES
  COMICS_GRAPHIC_NOVELS
  WEB_SERIALS
  CUSTOM_TIMELINE
}

enum ProgressMode {
  STRICT
  BRAVE
  FINISHED
}

enum ProgressCommandType {
  UPDATE
  ADVANCE_NEXT
}

enum PostType {
  DISCUSSION
  QUESTION
  THEORY
  PREDICTION
  POLL
  REACTION
  REVIEW
  IMAGE_MEME
  QUOTE_COMMENTARY
  JUST_REACHED
}

enum PostStatus {
  VISIBLE
  HIDDEN
}

enum PredictionStatus {
  UNRESOLVED
  CORRECT
  WRONG
  PARTIAL
}

enum CommentStatus {
  VISIBLE
  HIDDEN
}

enum NotificationType {
  POST_COMMENT
  COMMENT_REPLY
  PROGRESS_UNLOCK
  MODERATION_WARNING
}

enum AuditLogAction {
  POST_REQUIRED_MILESTONE_CHANGED
  POST_HIDDEN
  POST_DELETED
  COMMENT_REQUIRED_MILESTONE_CHANGED
  COMMENT_HIDDEN
  COMMENT_DELETED
  CLUB_MEMBER_ROLE_UPDATED
  USER_WARNED
  USER_BANNED
  USER_UNBANNED
  REPORT_RESOLVED
  REPORT_DISMISSED
}

enum ReportTargetType {
  POST
  COMMENT
}

enum ReportReason {
  SPOILER
  HARASSMENT
  HATE
  SPAM
  OFF_TOPIC
  OTHER
}

enum ReportStatus {
  OPEN
  RESOLVED
  DISMISSED
}

enum FileAssetPurpose {
  AVATAR
  CLUB_COVER
  POST_IMAGE
}

enum FileAssetVisibility {
  PUBLIC
  PRIVATE
}

enum FileAssetStatus {
  PENDING
  READY
  FAILED
}

enum StorageDeletionReason {
  INVALID_UPLOAD
  EXPIRED_UPLOAD
  UNATTACHED_POST_IMAGE
  REPLACED_ASSET
  ACCOUNT_DELETION
}

enum StorageDeletionStatus {
  PENDING
  COMPLETED
}

model User {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email          String    @db.VarChar(320)
  displayName    String    @map("display_name") @db.VarChar(80)
  username       String    @db.VarChar(30)
  bio            String?   @db.VarChar(160)
  avatarAssetId  String?   @unique(map: "users_avatar_asset_id_unique") @map("avatar_asset_id") @db.Uuid
  passwordHash   String    @map("password_hash")
  sessionVersion Int       @default(1) @map("session_version")
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  avatarAsset        FileAsset?            @relation("UserAvatarAsset", fields: [avatarAssetId], references: [id], onDelete: SetNull)
  clubMemberships    ClubMembership[]
  clubBans           ClubBan[]
  createdClubInvites ClubInvite[]          @relation("ClubInviteCreator")
  clubProgresses     ClubProgress[]
  progressHistory    ProgressHistory[]
  progressCommands   ProgressCommand[]
  posts              Post[]
  comments           Comment[]
  postReactions      PostReaction[]
  commentReactions   CommentReaction[]
  notifications      Notification[]
  reports            Report[]
  fileAssets         FileAsset[]           @relation("FileAssetOwner")
  auditLogsAuthored  AuditLog[]            @relation("AuditLogActor")
  auditLogsTargeting AuditLog[]            @relation("AuditLogTargetUser")
  nameReservations   UserNameReservation[]
  authSessions       AuthSession[]

  @@unique([email], map: "users_email_active_unique", where: raw("\"deleted_at\" IS NULL"))
  @@unique([username], map: "users_username_active_unique", where: raw("\"deleted_at\" IS NULL"))
  @@index([deletedAt], map: "users_deleted_at_idx")
  @@map("users")
}

model AuthSession {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           String    @map("user_id") @db.Uuid
  sessionIdHash    String    @unique(map: "auth_sessions_identifier_hash_unique") @map("session_identifier_hash") @db.Char(64)
  refreshTokenHash String    @unique(map: "auth_sessions_refresh_hash_unique") @map("refresh_token_hash") @db.Char(64)
  sessionVersion   Int       @map("session_version")
  expiresAt        DateTime  @map("expires_at") @db.Timestamptz(6)
  revokedAt        DateTime? @map("revoked_at") @db.Timestamptz(6)
  lastUsedAt       DateTime  @default(now()) @map("last_seen_at") @db.Timestamptz(6)
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt, expiresAt], map: "auth_sessions_user_active_idx")
  @@index([expiresAt], map: "auth_sessions_expires_at_idx")
  @@map("auth_sessions")
}

model UserNameReservation {
  normalizedName String   @id @map("normalized_name") @db.VarChar(80)
  userId         String   @map("user_id") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "user_name_reservations_user_id_idx")
  @@map("user_name_reservations")
}

model Club {
  id           String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title        String         @db.VarChar(120)
  linkName     String         @map("link_name") @db.VarChar(80)
  description  String?        @db.VarChar(280)
  category     ClubCategory
  rules        String?        @db.VarChar(2000)
  visibility   ClubVisibility @default(PUBLIC)
  coverAssetId String?        @unique(map: "clubs_cover_asset_id_unique") @map("cover_asset_id") @db.Uuid
  createdAt    DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime       @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  coverAsset       FileAsset?        @relation("ClubCoverAsset", fields: [coverAssetId], references: [id], onDelete: SetNull)
  memberships      ClubMembership[]
  invites          ClubInvite[]
  bans             ClubBan[]
  milestones       Milestone[]
  progress         ClubProgress[]
  history          ProgressHistory[]
  progressCommands ProgressCommand[]
  posts            Post[]
  notifications    Notification[]
  reports          Report[]
  fileAssets       FileAsset[]
  auditLogs        AuditLog[]

  @@unique([linkName], map: "clubs_link_name_unique")
  @@index([visibility], map: "clubs_visibility_idx")
  @@index([category], map: "clubs_category_idx")
  @@index([visibility, createdAt, id], map: "clubs_visibility_created_at_id_idx")
  @@map("clubs")
}

model ClubMembership {
  id        String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clubId    String             @map("club_id") @db.Uuid
  userId    String             @map("user_id") @db.Uuid
  role      ClubMembershipRole @default(MEMBER)
  createdAt DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime           @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, clubId], map: "club_memberships_user_id_club_id_unique")
  @@index([userId], map: "club_memberships_user_id_idx")
  @@index([userId, createdAt, id], map: "club_memberships_user_created_id_idx")
  @@index([clubId], map: "club_memberships_club_id_idx")
  @@index([clubId, role, createdAt, id], map: "club_memberships_club_role_created_id_idx")
  @@map("club_memberships")
}

model ClubBan {
  id        String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clubId    String              @map("club_id") @db.Uuid
  userId    String              @map("user_id") @db.Uuid
  reason    String?             @db.VarChar(500)
  roleAtBan ClubMembershipRole? @map("role_at_ban")
  expiresAt DateTime?           @map("expires_at") @db.Timestamptz(6)
  revokedAt DateTime?           @map("revoked_at") @db.Timestamptz(6)
  createdAt DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime            @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, clubId], map: "club_bans_user_id_club_id_idx")
  @@index([clubId, userId, revokedAt, expiresAt], map: "club_bans_active_lookup_idx")
  @@map("club_bans")
}

model ClubInvite {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clubId      String    @map("club_id") @db.Uuid
  createdById String    @map("created_by_id") @db.Uuid
  tokenHash   String    @map("token_hash") @db.VarChar(64)
  expiresAt   DateTime  @map("expires_at") @db.Timestamptz(6)
  maxUses     Int       @map("max_uses")
  usedCount   Int       @default(0) @map("used_count")
  revokedAt   DateTime? @map("revoked_at") @db.Timestamptz(6)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  club      Club @relation(fields: [clubId], references: [id], onDelete: Cascade)
  createdBy User @relation("ClubInviteCreator", fields: [createdById], references: [id], onDelete: Cascade)

  @@unique([tokenHash], map: "club_invites_token_hash_unique")
  @@index([clubId, createdAt], map: "club_invites_club_id_created_at_idx")
  @@index([createdById], map: "club_invites_created_by_id_idx")
  @@index([expiresAt], map: "club_invites_expires_at_idx")
  @@map("club_invites")
}

model Milestone {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clubId      String   @map("club_id") @db.Uuid
  position    Int
  safeTitle   String   @map("safe_title") @db.VarChar(120)
  fullTitle   String?  @map("full_title") @db.VarChar(160)
  description String?  @db.VarChar(500)
  spoilerName Boolean  @default(false) @map("spoiler_name")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  club                    Club              @relation(fields: [clubId], references: [id], onDelete: Cascade)
  currentClubProgresses   ClubProgress[]
  progressHistoryFromRows ProgressHistory[] @relation("ProgressHistoryFromMilestone")
  progressHistoryToRows   ProgressHistory[] @relation("ProgressHistoryToMilestone")
  posts                   Post[]
  comments                Comment[]
  predictionReveals       Prediction[]      @relation("PredictionRevealMilestone")
  notifications           Notification[]

  @@unique([clubId, position], map: "milestones_club_id_position_unique")
  @@index([clubId], map: "milestones_club_id_idx")
  @@map("milestones")
}

model ClubProgress {
  id                    String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clubId                String       @map("club_id") @db.Uuid
  userId                String       @map("user_id") @db.Uuid
  currentMilestoneId    String?      @map("current_milestone_id") @db.Uuid
  mode                  ProgressMode @default(STRICT)
  version               Int          @default(0)
  onboardingCompletedAt DateTime?    @map("onboarding_completed_at") @db.Timestamptz(6)
  createdAt             DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime     @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  club             Club       @relation(fields: [clubId], references: [id], onDelete: Cascade)
  user             User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  currentMilestone Milestone? @relation(fields: [currentMilestoneId], references: [id], onDelete: SetNull)

  @@unique([userId, clubId], map: "club_progress_user_id_club_id_unique")
  @@index([userId], map: "club_progress_user_id_idx")
  @@index([clubId], map: "club_progress_club_id_idx")
  @@index([currentMilestoneId], map: "club_progress_current_milestone_id_idx")
  @@map("club_progress")
}

model ProgressCommand {
  id          String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  commandId   String              @map("command_id") @db.Uuid
  userId      String              @map("user_id") @db.Uuid
  clubId      String              @map("club_id") @db.Uuid
  type        ProgressCommandType
  fingerprint String              @db.VarChar(160)
  createdAt   DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@unique([userId, clubId, commandId], map: "progress_commands_user_club_command_unique")
  @@index([createdAt], map: "progress_commands_created_at_idx")
  @@map("progress_commands")
}

model ProgressHistory {
  id              String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clubId          String       @map("club_id") @db.Uuid
  userId          String       @map("user_id") @db.Uuid
  fromMilestoneId String?      @map("from_milestone_id") @db.Uuid
  toMilestoneId   String?      @map("to_milestone_id") @db.Uuid
  fromMode        ProgressMode @map("from_mode")
  toMode          ProgressMode @map("to_mode")
  version         Int          @map("progress_version")
  createdAt       DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)

  club          Club       @relation(fields: [clubId], references: [id], onDelete: Cascade)
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  fromMilestone Milestone? @relation("ProgressHistoryFromMilestone", fields: [fromMilestoneId], references: [id], onDelete: SetNull)
  toMilestone   Milestone? @relation("ProgressHistoryToMilestone", fields: [toMilestoneId], references: [id], onDelete: SetNull)

  @@unique([userId, clubId, version], map: "progress_history_user_club_version_unique")
  @@index([userId, clubId, createdAt], map: "progress_history_user_id_club_id_created_at_idx")
  @@index([clubId, createdAt], map: "progress_history_club_id_created_at_idx")
  @@index([fromMilestoneId], map: "progress_history_from_milestone_id_idx")
  @@index([toMilestoneId], map: "progress_history_to_milestone_id_idx")
  @@map("progress_history")
}

model Post {
  id                  String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clubId              String     @map("club_id") @db.Uuid
  authorId            String     @map("author_id") @db.Uuid
  type                PostType
  title               String     @db.VarChar(160)
  body                String     @db.VarChar(8000)
  requiredMilestoneId String     @map("required_milestone_id") @db.Uuid
  status              PostStatus @default(VISIBLE)
  deletedAt           DateTime?  @map("deleted_at") @db.Timestamptz(6)
  createdAt           DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime   @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  club              Club           @relation(fields: [clubId], references: [id], onDelete: Cascade)
  author            User           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  requiredMilestone Milestone      @relation(fields: [requiredMilestoneId], references: [id], onDelete: Restrict)
  comments          Comment[]
  reactions         PostReaction[]
  prediction        Prediction?
  notifications     Notification[]
  mediaAssets       FileAsset[]    @relation("PostMediaAssets")
  reports           Report[]
  auditLogs         AuditLog[]

  @@index([clubId, status, deletedAt, createdAt], map: "posts_club_id_status_deleted_at_created_at_idx")
  @@index([clubId, status, deletedAt, createdAt, id], map: "posts_club_status_deleted_created_id_idx")
  @@index([clubId, authorId, status, deletedAt, createdAt, id], map: "posts_club_author_status_deleted_created_id_idx")
  @@index([clubId, requiredMilestoneId], map: "posts_club_id_required_milestone_id_idx")
  @@index([authorId], map: "posts_author_id_idx")
  @@index([requiredMilestoneId], map: "posts_required_milestone_id_idx")
  @@map("posts")
}

model Prediction {
  id                String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  postId            String           @unique(map: "predictions_post_id_unique") @map("post_id") @db.Uuid
  revealMilestoneId String           @map("reveal_milestone_id") @db.Uuid
  status            PredictionStatus @default(UNRESOLVED)
  createdAt         DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime         @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  post            Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  revealMilestone Milestone @relation("PredictionRevealMilestone", fields: [revealMilestoneId], references: [id], onDelete: Restrict)

  @@index([postId], map: "predictions_post_id_idx")
  @@index([revealMilestoneId], map: "predictions_reveal_milestone_id_idx")
  @@map("predictions")
}

model PostReaction {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  postId    String   @map("post_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  emoji     String   @db.VarChar(16)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, postId, emoji], map: "post_reactions_user_id_post_id_emoji_unique")
  @@index([postId], map: "post_reactions_post_id_idx")
  @@index([postId, emoji], map: "post_reactions_post_id_emoji_idx")
  @@index([userId], map: "post_reactions_user_id_idx")
  @@map("post_reactions")
}

model Comment {
  id                  String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  postId              String        @map("post_id") @db.Uuid
  authorId            String        @map("author_id") @db.Uuid
  parentId            String?       @map("parent_id") @db.Uuid
  body                String        @db.VarChar(8000)
  requiredMilestoneId String        @map("required_milestone_id") @db.Uuid
  status              CommentStatus @default(VISIBLE)
  deletedAt           DateTime?     @map("deleted_at") @db.Timestamptz(6)
  createdAt           DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  post              Post              @relation(fields: [postId], references: [id], onDelete: Cascade)
  author            User              @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent            Comment?          @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies           Comment[]         @relation("CommentReplies")
  requiredMilestone Milestone         @relation(fields: [requiredMilestoneId], references: [id], onDelete: Restrict)
  reactions         CommentReaction[]
  notifications     Notification[]
  mediaAssets       FileAsset[]       @relation("CommentMediaAssets")
  reports           Report[]
  auditLogs         AuditLog[]

  @@index([postId, status, deletedAt, createdAt], map: "comments_post_id_status_deleted_at_created_at_idx")
  @@index([postId, status, deletedAt, createdAt, id], map: "comments_post_status_deleted_created_id_idx")
  @@index([postId, requiredMilestoneId], map: "comments_post_id_required_milestone_id_idx")
  @@index([authorId], map: "comments_author_id_idx")
  @@index([parentId], map: "comments_parent_id_idx")
  @@index([requiredMilestoneId], map: "comments_required_milestone_id_idx")
  @@map("comments")
}

model CommentReaction {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  commentId String   @map("comment_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  emoji     String   @db.VarChar(16)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, commentId, emoji], map: "comment_reactions_user_id_comment_id_emoji_unique")
  @@index([commentId], map: "comment_reactions_comment_id_idx")
  @@index([commentId, emoji], map: "comment_reactions_comment_id_emoji_idx")
  @@index([userId], map: "comment_reactions_user_id_idx")
  @@map("comment_reactions")
}

model Notification {
  id                  String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId              String           @map("user_id") @db.Uuid
  type                NotificationType
  eventKey            String           @map("event_key") @db.VarChar(160)
  safeText            String           @map("safe_text") @db.VarChar(240)
  clubId              String           @map("club_id") @db.Uuid
  postId              String?          @map("post_id") @db.Uuid
  commentId           String?          @map("comment_id") @db.Uuid
  requiredMilestoneId String           @map("required_milestone_id") @db.Uuid
  readAt              DateTime?        @map("read_at") @db.Timestamptz(6)
  createdAt           DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)

  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  club              Club      @relation(fields: [clubId], references: [id], onDelete: Cascade)
  post              Post?     @relation(fields: [postId], references: [id], onDelete: Cascade)
  comment           Comment?  @relation(fields: [commentId], references: [id], onDelete: Cascade)
  requiredMilestone Milestone @relation(fields: [requiredMilestoneId], references: [id], onDelete: Restrict)

  @@unique([eventKey], map: "notifications_event_key_unique")
  @@index([userId, readAt, createdAt], map: "notifications_user_id_read_at_created_at_idx")
  @@index([userId, createdAt], map: "notifications_user_id_created_at_idx")
  @@index([userId, createdAt, id], map: "notifications_user_id_created_at_id_idx")
  @@index([clubId], map: "notifications_club_id_idx")
  @@index([postId], map: "notifications_post_id_idx")
  @@index([commentId], map: "notifications_comment_id_idx")
  @@index([requiredMilestoneId], map: "notifications_required_milestone_id_idx")
  @@map("notifications")
}

model Report {
  id         String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  targetType ReportTargetType @map("target_type")
  reason     ReportReason
  details    String?          @db.VarChar(1000)
  reporterId String           @map("reporter_id") @db.Uuid
  clubId     String           @map("club_id") @db.Uuid
  postId     String?          @map("post_id") @db.Uuid
  commentId  String?          @map("comment_id") @db.Uuid
  status     ReportStatus     @default(OPEN)
  createdAt  DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime         @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  reporter  User       @relation(fields: [reporterId], references: [id], onDelete: Cascade)
  club      Club       @relation(fields: [clubId], references: [id], onDelete: Cascade)
  post      Post?      @relation(fields: [postId], references: [id], onDelete: Cascade)
  comment   Comment?   @relation(fields: [commentId], references: [id], onDelete: Cascade)
  auditLogs AuditLog[]

  @@unique([reporterId, postId], map: "reports_reporter_id_post_id_open_unique", where: raw("\"status\" = 'OPEN' AND \"post_id\" IS NOT NULL"))
  @@unique([reporterId, commentId], map: "reports_reporter_id_comment_id_open_unique", where: raw("\"status\" = 'OPEN' AND \"comment_id\" IS NOT NULL"))
  @@index([clubId, status, createdAt], map: "reports_club_id_status_created_at_idx")
  @@index([clubId, status, createdAt, id], map: "reports_club_status_created_id_idx")
  @@index([reporterId, createdAt], map: "reports_reporter_id_created_at_idx")
  @@index([postId], map: "reports_post_id_idx")
  @@index([commentId], map: "reports_comment_id_idx")
  @@map("reports")
}

model AuditLog {
  id               String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  action           AuditLogAction
  actorId          String?        @map("actor_id") @db.Uuid
  actorDisplayName String         @map("actor_display_name") @db.VarChar(80)
  actorUsername    String         @map("actor_username") @db.VarChar(30)
  clubId           String?        @map("club_id") @db.Uuid
  clubTitle        String         @map("club_title") @db.VarChar(120)
  clubLinkName     String         @map("club_link_name") @db.VarChar(80)
  reportId         String?        @map("report_id") @db.Uuid
  postId           String?        @map("post_id") @db.Uuid
  commentId        String?        @map("comment_id") @db.Uuid
  targetUserId     String?        @map("target_user_id") @db.Uuid
  moderatorNote    String?        @map("moderator_note") @db.VarChar(1000)
  metadata         Json?
  createdAt        DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)

  actor      User?    @relation("AuditLogActor", fields: [actorId], references: [id], onDelete: SetNull)
  club       Club?    @relation(fields: [clubId], references: [id], onDelete: SetNull)
  report     Report?  @relation(fields: [reportId], references: [id], onDelete: SetNull)
  post       Post?    @relation(fields: [postId], references: [id], onDelete: SetNull)
  comment    Comment? @relation(fields: [commentId], references: [id], onDelete: SetNull)
  targetUser User?    @relation("AuditLogTargetUser", fields: [targetUserId], references: [id], onDelete: SetNull)

  @@index([clubId, createdAt], map: "audit_logs_club_id_created_at_idx")
  @@index([clubId, action, createdAt], map: "audit_logs_club_id_action_created_at_idx")
  @@index([actorId, createdAt], map: "audit_logs_actor_id_created_at_idx")
  @@index([targetUserId, createdAt], map: "audit_logs_target_user_id_created_at_idx")
  @@index([reportId], map: "audit_logs_report_id_idx")
  @@index([postId], map: "audit_logs_post_id_idx")
  @@index([commentId], map: "audit_logs_comment_id_idx")
  @@map("audit_logs")
}

model FileAsset {
  id          String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ownerId     String              @map("owner_id") @db.Uuid
  clubId      String?             @map("club_id") @db.Uuid
  postId      String?             @map("post_id") @db.Uuid
  commentId   String?             @map("comment_id") @db.Uuid
  purpose     FileAssetPurpose
  visibility  FileAssetVisibility @default(PUBLIC)
  safePreview Boolean             @default(false) @map("safe_preview")
  objectKey   String              @unique(map: "file_assets_object_key_unique") @map("object_key") @db.VarChar(512)
  contentType String              @map("content_type") @db.VarChar(120)
  sizeBytes   Int                 @map("size_bytes")
  status      FileAssetStatus     @default(PENDING)
  widthPx     Int?                @map("width_px")
  heightPx    Int?                @map("height_px")
  isAnimated  Boolean?            @map("is_animated")
  validatedAt DateTime?           @map("validated_at") @db.Timestamptz(6)
  readyAt     DateTime?           @map("ready_at") @db.Timestamptz(6)
  createdAt   DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime            @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  owner         User     @relation("FileAssetOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  club          Club?    @relation(fields: [clubId], references: [id], onDelete: Cascade)
  post          Post?    @relation("PostMediaAssets", fields: [postId], references: [id], onDelete: Cascade)
  comment       Comment? @relation("CommentMediaAssets", fields: [commentId], references: [id], onDelete: Cascade)
  avatarForUser User?    @relation("UserAvatarAsset")
  coverForClub  Club?    @relation("ClubCoverAsset")

  @@index([ownerId, purpose, status, createdAt], map: "file_assets_owner_purpose_status_created_at_idx")
  @@index([clubId, purpose, status, createdAt], map: "file_assets_club_purpose_status_created_at_idx")
  @@index([postId, purpose, status], map: "file_assets_post_purpose_status_idx")
  @@index([commentId, purpose, status], map: "file_assets_comment_purpose_status_idx")
  @@index([status, createdAt], map: "file_assets_status_created_at_idx")
  @@map("file_assets")
}

model StorageObjectDeletion {
  id          String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  objectKey   String                @unique(map: "storage_object_deletions_object_key_unique") @map("object_key") @db.VarChar(512)
  reason      StorageDeletionReason
  status      StorageDeletionStatus @default(PENDING)
  attempts    Int                   @default(0)
  lastError   String?               @map("last_error") @db.VarChar(500)
  completedAt DateTime?             @map("completed_at") @db.Timestamptz(6)
  createdAt   DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime              @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([status, updatedAt], map: "storage_object_deletions_status_updated_at_idx")
  @@map("storage_object_deletions")
}
